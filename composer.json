{
    "name": "vusys/laravel-quantum-slipstream-drive",
    "description": "A Laravel package.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "infection/infection": "^0.29 || ^0.33 || ^0.34",
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0|^13.0",
        "rector/rector": "^2.0",
        "vusys/laravel-runabout": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "Vusys\\QuantumSlipstreamDrive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vusys\\QuantumSlipstreamDrive\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vusys\\QuantumSlipstreamDrive\\QuantumSlipstreamDriveServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        },
        "policy": {
            "advisories": {
                "ignore-id": [
                    "PKSA-m5cs-t1y6-qpcs",
                    "PKSA-3r5d-mb8f-1qw9",
                    "PKSA-mdq4-51ck-6kdq",
                    "PKSA-8qx3-n5y5-vvnd",
                    "PKSA-q46n-4fdk-zjr4",
                    "PKSA-qzrn-rnz3-85w1",
                    "PKSA-w7xr-vk7n-rstm"
                ]
            }
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "analyze": "@analyse",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "pint": "pint",
        "pint:check": "pint --test",
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "test:coverage-html": "XDEBUG_MODE=coverage phpunit --coverage-html=build/coverage",
        "fuzz": "phpunit --group fuzzer",
        "mutate": "infection --threads=4 --no-progress"
    }
}
